@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam roundcorner 18
skinparam backgroundColor #F7FBFF
skinparam class {
  BackgroundColor #EAF4FF
  BorderColor #185FA5
  ArrowColor #185FA5
}

class Usuario {
  +id: string
  +name: string
  +email: string
  +password: string
  +role: Rol
  +status: string
  +phone: string
  +tienePermiso(action): boolean
  +toJSON(): object
}

class Paciente {
  +id: string
  +name: string
  +dni: string
  +phone: string
  +email: string
  +birth: string
  +history: array
  +agregarHistorial(evento): void
  +toJSON(): object
}

class Medico {
  +id: string
  +name: string
  +specialty: string
  +email: string
  +phone: string
  +assignedPatients: array
  +blockedSlots: array
  +asignarPaciente(patientId): void
  +toJSON(): object
}

class Cita {
  +id: string
  +type: TipoCita
  +patientId: string
  +doctorId: string
  +date: string
  +time: string
  +status: EstadoCita
  +detail: string
  +resumen(): string
  +cambiarEstado(status): void
  +toJSON(): object
}

class CitaConsulta
class CitaTelemedicina
class CitaLaboratorio

Cita <|-- CitaConsulta
Cita <|-- CitaTelemedicina
Cita <|-- CitaLaboratorio
Paciente "1" -- "0..*" Cita : agenda
Medico "1" -- "0..*" Cita : atiende
Usuario "1" -- "0..1" Paciente : vincula
Usuario "1" -- "0..1" Medico : vincula

class CitaFactory <<Factory Method>> {
  +create(cita): Cita
}

class Strategy <<Strategy>> {
  +assign(strategy, date, doctorId, ignoreId): string
}

class Observer <<Observer>> {
  +notifyAppointment(cita, title, message): void
}

class SMSAdapter <<Adapter>> {
  +send(patientId, message): void
}

class Contract {
  +require(condition, message): void
  +ensure(condition, message): void
}

class MediCitasException
class ValidacionException
class AccesoNoPermitidoException
class EntidadNoEncontradaException
class EstadoInvalidoException
class HorarioOcupadoException

MediCitasException <|-- ValidacionException
MediCitasException <|-- AccesoNoPermitidoException
MediCitasException <|-- EntidadNoEncontradaException
MediCitasException <|-- EstadoInvalidoException
MediCitasException <|-- HorarioOcupadoException

CitaFactory ..> CitaConsulta : crea
CitaFactory ..> CitaTelemedicina : crea
CitaFactory ..> CitaLaboratorio : crea
Strategy ..> Cita : asigna horario
Observer ..> SMSAdapter : notifica por canal
Contract ..> MediCitasException : lanza
@enduml
